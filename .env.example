# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# Stripe
# Disabled by default. Set true only after configuring real provider credentials.
PAYMENTS_ENABLED=false
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
STRIPE_STARTER_PRICE_ID=REPLACE_WITH_STRIPE_STARTER_PRICE_ID
STRIPE_PRO_PRICE_ID=REPLACE_WITH_STRIPE_PRO_PRICE_ID
STRIPE_ENTERPRISE_PRICE_ID=REPLACE_WITH_STRIPE_ENTERPRISE_PRICE_ID

# OpenAI
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# App
NEXT_PUBLIC_APP_URL=https://aurorarayes.example/complianceos
NEXTAUTH_SECRET=REPLACE_WITH_NEXTAUTH_SECRET_MIN_32_CHARS

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx
SENTRY_AUTH_TOKEN=REPLACE_WITH_SENTRY_AUTH_TOKEN

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_UPSTASH_REDIS_REST_TOKEN